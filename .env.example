# Grant OS — environment variables
# Copy to .env.local and fill in. NEVER commit real secrets (.env.local is gitignored).

# --- Database (MongoDB Atlas) ---
# Atlas connection string. Whitelist your IP (local) and 0.0.0.0/0 or Vercel egress (deploy).
MONGODB_URI=

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=
# Optional: override the default model (claude-sonnet-4-6). Use claude-opus-4-8 for max quality.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Auth (NextAuth v5 / Auth.js) ---
# Generate with: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=
# Set to your deployed URL in production, e.g. https://grant-os.vercel.app
# NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — leave blank to use email/password only)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- File storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- Seed (optional) ---
# Org name + admin used by scripts/seed.ts on first run.
SEED_ORG_NAME=My Organization
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Billing (Stripe) — V2, scaffold only, leave blank for now ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
